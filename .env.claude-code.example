# Source this file in the terminal where you run Claude Code.
# Keep it separate from the proxy server .env file.

ANTHROPIC_BASE_URL=http://127.0.0.1:8787
ANTHROPIC_API_KEY=dummy-claude-model-proxy

# Pin Claude Code aliases to proxy semantic aliases. The proxy's
# CLAUDE_MODEL_MAP decides which real upstream models these aliases use.
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus
CLAUDE_CODE_SUBAGENT_MODEL=claude-haiku

# Start Claude Code on the pinned Sonnet alias by default.
ANTHROPIC_MODEL=sonnet
